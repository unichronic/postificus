{
  "manifest_version": 2,
  "name": "Postificus Connector",
  "version": "1.0.0",
  "description": "Automatically connects your Medium and Dev.to accounts to Postificus.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "https://dev.to/*",
    "https://medium.com/*",
    "https://postificus-api.onrender.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "icons": {
    "48": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "postificus@connector",
      "strict_min_version": "109.0"
    }
  }
}
